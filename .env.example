# ============================================================
# VPN Platform — Environment Variables
# Скопируй этот файл в .env и заполни значения
# ============================================================

# ----------------------------------------------------------
# Telegram Bot
# ----------------------------------------------------------
BOT_TOKEN=your_bot_token_here
ADMIN_IDS=123456789,987654321          # Telegram ID администраторов (через запятую)

# ----------------------------------------------------------
# PostgreSQL
# ----------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=vpnplatform
POSTGRES_USER=vpnuser
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# ----------------------------------------------------------
# Redis
# ----------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_redis_password
REDIS_DB=0

# ----------------------------------------------------------
# Marzban VPN Panel
# ----------------------------------------------------------
MARZBAN_URL=https://panel.yourdomain.com      # URL панели Marzban (без слеша в конце)
MARZBAN_USERNAME=admin                         # Логин администратора Marzban
MARZBAN_PASSWORD=CHANGE_ME_marzban_password    # Пароль администратора Marzban

# ----------------------------------------------------------
# Домены для VPN подписки (ротация анти-блок)
# ----------------------------------------------------------
VPN_DOMAINS=sub1.yourdomain.com,sub2.yourdomain.com,sub3.yourdomain.com
PRIMARY_DOMAIN=sub1.yourdomain.com

# ----------------------------------------------------------
# YooKassa — основная платёжная система
# ----------------------------------------------------------
YOOKASSA_SHOP_ID=your_shop_id
YOOKASSA_SECRET_KEY=your_secret_key
YOOKASSA_RETURN_URL=https://t.me/your_bot_name

# ----------------------------------------------------------
# SBP / ЮMoney — резервная оплата
# ----------------------------------------------------------
SBP_PHONE=+79001234567                 # Номер телефона для СБП
SBP_BANK_NAME=Сбербанк                 # Название банка

# ----------------------------------------------------------
# Тарифы (в рублях)
# ----------------------------------------------------------
PRICE_1_MONTH=100
PRICE_3_MONTHS=290
PRICE_6_MONTHS=590
PRICE_12_MONTHS=1200

# ----------------------------------------------------------
# Реферальная система
# ----------------------------------------------------------
REFERRAL_BONUS_DAYS=30                 # Дней бонуса за приглашение

# ----------------------------------------------------------
# Лимиты VPN пользователя
# ----------------------------------------------------------
VPN_IP_LIMIT=3                         # Максимум устройств на одного пользователя
VPN_DEFAULT_TRAFFIC_GB=0               # 0 = безлимитный трафик

# ----------------------------------------------------------
# Балансировка нод
# ----------------------------------------------------------
NODE_NEAR_CAPACITY_THRESHOLD=80        # % загрузки — «почти полная»
NODE_FULL_THRESHOLD=95                 # % загрузки — не добавлять новых

# ----------------------------------------------------------
# Rate Limiting (Redis)
# ----------------------------------------------------------
RATE_LIMIT_MESSAGES=30                 # Сообщений в минуту на пользователя
RATE_LIMIT_WINDOW=60                   # Окно в секундах

# ----------------------------------------------------------
# Уведомления об истечении подписки (дни)
# ----------------------------------------------------------
NOTIFY_DAYS_BEFORE=[3, 1]

# ----------------------------------------------------------
# Мониторинг
# ----------------------------------------------------------
NODE_ALERT_THRESHOLD=80                # % загрузки — алерт администратору

# ----------------------------------------------------------
# Окружение
# ----------------------------------------------------------
ENVIRONMENT=production                 # production / development
LOG_LEVEL=INFO
